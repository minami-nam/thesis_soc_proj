############################################################
# Vivado / Xilinx generated directories
############################################################

# Vivado internal / cache directories
.Xil/
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.gen/

# Xilinx simulation directory
xsim.dir/

# Vivado block design generated products
*.srcs/sources_1/bd/*/ip/
*.srcs/sources_1/bd/*/ipshared/
*.srcs/sources_1/bd/*/synth/
*.srcs/sources_1/bd/*/sim/
*.srcs/sources_1/bd/*/hw_handoff/
*.srcs/sources_1/bd/*/ui/
*.srcs/sources_1/bd/*/*.bxml


############################################################
# Vivado / Xilinx generated files
############################################################

# Logs / journals / messages
*.jou
*.log
*.str
*.xmsgs

# Simulation outputs
*.wdb
*.vcd
*.fst
*.vpd
*.saif
*.wcfg

# Design checkpoints / reports / generated database files
*.dcp
*.rpt
*.pb

# Generated hardware outputs
*.bit
*.bin
*.ltx
*.mcs
*.prm
*.mmi
*.hdf
*.xsa

# WebTalk / usage statistics
webtalk*.jou
webtalk*.log
usage_statistics_webtalk.*

# IP generated output products
*_stub.v
*_stub.vhdl
*_funcsim.v
*_funcsim.vhdl
*_sim_netlist.v
*_sim_netlist.vhdl
*_synth.v
*_synth.vhdl


